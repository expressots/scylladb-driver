{
  "name": "scylladb-driver",
  "version": "1.0.0-preview.1",
  "description": "High-performance ScyllaDB/Cassandra CQL driver for Node.js, built on the official Rust driver via NAPI",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/expressots/scylladb-driver.git"
  },
  "bugs": {
    "url": "https://github.com/expressots/scylladb-driver/issues"
  },
  "homepage": "https://github.com/expressots/scylladb-driver#readme",
  "keywords": [
    "scylladb",
    "cassandra",
    "cql",
    "driver",
    "napi",
    "expressots",
    "database"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./ts": {
      "types": "./ts/index.ts",
      "default": "./ts/index.ts"
    }
  },
  "napi": {
    "name": "scylladb-driver",
    "triples": {}
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^2.16.1",
    "@types/node": "^22.15.21",
    "ava": "^5.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  },
  "ava": {
    "timeout": "3m"
  },
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "ts"
  ],
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "clean": "rm -rf target *.node index.js index.d.ts *.tgz npm/*/scylladb-driver.*.node",
    "dev": "tsnd --respawn --transpile-only --no-notify ./driver_api/main.ts",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d --wait",
    "docker:down": "docker compose -f docker/docker-compose.yml down -v",
    "pack:ci": "napi prepublish -t npm && npm pack && node scripts/verify-pack.mjs",
    "pack:local": "yarn build && yarn pack:ci",
    "prepublishOnly": "napi prepublish -t npm",
    "publish:preview": "bash scripts/publish-preview.sh",
    "test": "ava __test__/uuid.spec.mjs",
    "test:integration": "ava __test__/integration/**/*.mjs",
    "test:all": "ava __test__/**/*.mjs",
    "universal": "napi universal",
    "verify:pack": "node scripts/verify-pack.mjs",
    "version": "napi version"
  }
}